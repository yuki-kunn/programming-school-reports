<% content_for :title, "日報詳細" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-section-heading text-plum-black mb-6">日報詳細</h1>

  <%= render @report %>

  <div class="flex flex-wrap gap-2 mt-6">
    <% if current_user == @report.user %>
      <%= link_to "編集", edit_report_path(@report), class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
      <%= button_to "削除", @report, method: :delete, class: "rounded-button px-3.5 py-2.5 bg-error-red hover:bg-red-700 text-black font-normal text-button cursor-pointer", data: { turbo_confirm: "本当に削除しますか？" } %>
    <% end %>
    <%= link_to "一覧に戻る", reports_path, class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
  </div>
</div>
