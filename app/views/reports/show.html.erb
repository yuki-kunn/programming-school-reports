<% content_for :title, "日報詳細" %>

<div class="max-w-3xl">
  <%= render "shared/back_link", label: "← 日報一覧", url: reports_path %>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-4 sm:p-8">
    <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between mb-6">
      <div>
        <h1 class="text-xl font-bold text-slate-900">日報詳細</h1>
        <div class="flex items-center gap-3 mt-2">
          <span class="text-sm font-medium text-indigo-600 bg-indigo-50 rounded-full px-3 py-1">
            <%= @report.learning_date.strftime("%Y年%-m月%-d日") %>
          </span>
        </div>
      </div>
      <% if current_user == @report.user || current_user.admin? %>
        <div class="flex items-center gap-2">
          <%= link_to "編集", edit_report_path(@report),
              class: "text-sm font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-lg px-3 py-1.5 transition-colors" %>
          <%= button_to "削除", @report, method: :delete,
              class: "text-sm font-medium text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 rounded-lg px-3 py-1.5 transition-colors cursor-pointer bg-transparent",
              data: { turbo_confirm: "この日報を削除しますか？" } %>
        </div>
      <% end %>
    </div>

    <dl class="space-y-5">
      <div class="flex gap-4 py-4 border-t border-slate-100">
        <dt class="w-24 shrink-0 text-sm font-medium text-slate-500">生徒</dt>
        <dd class="text-sm text-slate-900 font-medium"><%= @report.student.name %></dd>
      </div>
      <div class="flex gap-4 py-4 border-t border-slate-100">
        <dt class="w-24 shrink-0 text-sm font-medium text-slate-500">記入者</dt>
        <dd class="text-sm text-slate-900"><%= @report.user.name %></dd>
      </div>
      <div class="py-4 border-t border-slate-100">
        <dt class="text-sm font-medium text-slate-500 mb-3">学習内容</dt>
        <dd class="text-sm text-slate-900 leading-relaxed whitespace-pre-wrap"><%= @report.content %></dd>
      </div>
    </dl>
  </div>
</div>
