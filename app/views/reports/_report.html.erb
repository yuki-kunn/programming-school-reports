<div id="<%= dom_id report %>">
  <div class="flex items-center gap-2 flex-wrap mb-1">
    <span class="text-xs font-medium text-indigo-600">
      <%= report.learning_date.strftime("%Y年%-m月%-d日") %>
    </span>
    <span class="text-xs text-slate-400">|</span>
    <span class="text-xs text-slate-500"><%= report.student.name %></span>
    <span class="text-xs text-slate-400">|</span>
    <span class="text-xs text-slate-400">記入: <%= report.user.name %></span>
  </div>
  <p class="text-sm text-slate-700 mt-1 line-clamp-2">
    <%= truncate(report.content, length: 120) %>
  </p>
</div>
