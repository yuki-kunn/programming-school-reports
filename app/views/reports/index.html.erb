<% content_for :title, "日報一覧" %>

<%= render "shared/page_header",
    title: "日報一覧",
    subtitle: "学習の記録を管理します",
    action: link_to("＋ 新規日報", new_report_path,
      class: "inline-flex items-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors") %>

<%# タグフィルタータブ %>
<div class="flex flex-wrap gap-2 mb-6">
  <%= link_to "すべて", reports_path,
      class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{@current_tag.nil? ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-indigo-300 hover:text-indigo-600'}" %>
  <% @tags.each do |tag| %>
    <%= link_to tag.name, reports_path(tag_id: tag.id),
        class: "px-4 py-2 rounded-full text-sm font-medium transition-colors #{@current_tag == tag ? 'bg-indigo-600 text-white' : 'bg-white text-slate-600 border border-slate-200 hover:border-indigo-300 hover:text-indigo-600'}" %>
  <% end %>
</div>

<% if @current_tag %>
  <p class="text-sm text-slate-500 mb-4">
    <span class="font-medium text-slate-700"><%= @current_tag.name %></span> の日報
    <span class="ml-1 text-slate-400">(<%= @reports.total_count %>件)</span>
  </p>
<% end %>

<% if @reports.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="divide-y divide-slate-100">
      <% @reports.each do |report| %>
        <div class="px-6 py-4 hover:bg-slate-50 transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1.5">
                <span class="text-xs font-medium text-indigo-600 bg-indigo-50 rounded-full px-2.5 py-0.5">
                  <%= japanese_date(report.learning_date) %>
                </span>
                <span class="text-xs text-slate-500">
                  <%= report.student.name %> の日報
                </span>
                <span class="text-xs text-slate-400">
                  記入者: <%= report.user.name %>
                </span>
              </div>
              <p class="text-sm text-slate-700 line-clamp-2">
                <%= truncate(report.content, length: 120) %>
              </p>
            </div>
            <div class="flex flex-wrap items-center gap-1">
              <%= link_to "詳細", report,
                  class: "text-xs font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-md px-3 py-1.5 transition-colors" %>
              <% if current_user == report.user || admin_or_above? %>
                <%= link_to "編集", edit_report_path(report),
                    class: "text-xs font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-md px-3 py-1.5 transition-colors" %>
                <%= button_to "削除", report, method: :delete,
                    class: "text-xs font-medium text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 rounded-md px-3 py-1.5 transition-colors cursor-pointer bg-transparent",
                    data: { turbo_confirm: "この日報を削除しますか？" } %>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
  <%= paginate @reports %>
<% else %>
  <%= render "shared/empty_state",
      icon: "📝",
      message: "まだ日報がありません",
      sub_message: "最初の日報を作成しましょう",
      action: link_to("日報を作成する", new_report_path,
        class: "inline-flex mt-6 items-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white transition-colors") %>
<% end %>
