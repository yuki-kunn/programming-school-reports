<% content_for :title, "日報編集" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-section-heading text-plum-black mb-6">日報編集</h1>

  <%= render "form", report: @report %>

  <div class="flex flex-wrap gap-2 mt-4">
    <%= link_to "詳細に戻る", @report, class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
    <%= link_to "一覧に戻る", reports_path, class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
  </div>
</div>
