<% content_for :title, "講師管理" %>

<%= render "shared/page_header",
    title: "講師管理",
    subtitle: "ユーザーの一覧と権限管理",
    action: link_to("＋ ユーザー追加", new_admin_user_path,
      class: "inline-flex items-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors") %>

<% if @users.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-slate-200 bg-slate-50">
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">名前</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">メールアドレス</th>
            <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">権限</th>
            <th class="px-6 py-3"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-slate-100">
          <% @users.each do |user| %>
            <tr class="<%= user.active? ? 'hover:bg-slate-50' : 'bg-slate-100 opacity-60' %> transition-colors">
              <td class="px-6 py-4 font-medium text-slate-900">
                <div class="flex items-center gap-3">
                  <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-sm font-bold shrink-0">
                    <%= user.name&.chars&.first || "?" %>
                  </div>
                  <span><%= user.name %></span>
                  <% unless user.active? %>
                    <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium bg-red-100 text-red-600">無効</span>
                  <% end %>
                </div>
              </td>
              <td class="px-6 py-4 text-slate-500"><%= user.email %></td>
              <td class="px-6 py-4"><%= user_role_badge(user) %></td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-1">
                  <%= link_to "詳細", admin_user_path(user),
                      class: "text-xs font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-md px-3 py-1.5 transition-colors" %>
                  <% unless user == current_user || user.superadmin? %>
                    <%= button_to "削除", admin_user_path(user),
                        method: :delete,
                        class: "text-xs font-medium text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 rounded-md px-3 py-1.5 transition-colors cursor-pointer bg-transparent",
                        data: { turbo_confirm: "#{h(user.name)} のアカウントを削除しますか？" } %>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
  <%= paginate @users %>
<% else %>
  <%= render "shared/empty_state",
      icon: "👥",
      message: "ユーザーが見つかりませんでした" %>
<% end %>
