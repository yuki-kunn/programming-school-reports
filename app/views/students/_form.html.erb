<%= form_with(model: student, local: true, class: "space-y-6") do |form| %>
  <%= render "shared/form_errors", object: student %>

  <div>
    <%= form.label :name, "名前", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.text_field :name,
        placeholder: "山田 花子",
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
  </div>

  <div>
    <%= form.label :admission_date, "入学日", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.date_field :admission_date,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
  </div>

  <div>
    <%= form.label :enrollment_status, "在籍状況", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.select :enrollment_status,
        [["在籍中", "active"], ["卒業", "graduated"], ["休学中", "on_leave"]],
        { prompt: "選択してください" },
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
  </div>

  <div>
    <%= form.label :tag_id, "カテゴリタグ", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <%= form.collection_select :tag_id, @tags, :id, :name,
        { prompt: "タグなし（選択任意）", include_blank: true },
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
  </div>

  <div>
    <%= form.label :memo, "メモ", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
    <p class="text-xs text-slate-400 mb-1.5">特記事項があれば入力してください</p>
    <%= form.text_area :memo, rows: 4,
        class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition resize-y" %>
  </div>

  <div class="flex justify-end">
    <%= form.submit class: "inline-flex justify-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-6 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors cursor-pointer" %>
  </div>
<% end %>
