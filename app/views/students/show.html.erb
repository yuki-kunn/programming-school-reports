<% content_for :title, "生徒詳細" %>

<div class="max-w-3xl">
  <div class="flex items-center gap-2 mb-6">
    <%= link_to "← 生徒一覧", students_path,
        class: "text-sm text-slate-500 hover:text-indigo-600 transition-colors" %>
  </div>

  <div class="bg-white rounded-xl shadow-sm border border-slate-200 p-8">
    <div class="flex items-start justify-between mb-6">
      <div class="flex items-center gap-4">
        <div class="w-12 h-12 rounded-full bg-indigo-100 flex items-center justify-center text-indigo-600 text-xl font-bold">
          <%= @student.name.chars.first %>
        </div>
        <div>
          <h1 class="text-xl font-bold text-slate-900"><%= @student.name %></h1>
          <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium mt-1 <%= enrollment_status_badge_class(@student.enrollment_status) %>">
            <%= enrollment_status_label(@student.enrollment_status) %>
          </span>
        </div>
      </div>
      <% if current_user&.admin? %>
        <div class="flex items-center gap-2">
          <%= link_to "編集", edit_student_path(@student),
              class: "text-sm font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-lg px-3 py-1.5 transition-colors" %>
          <%= button_to "削除", @student, method: :delete,
              class: "text-sm font-medium text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 rounded-lg px-3 py-1.5 transition-colors cursor-pointer bg-transparent",
              data: { turbo_confirm: "#{@student.name} を削除しますか？" } %>
        </div>
      <% end %>
    </div>

    <dl class="space-y-0 divide-y divide-slate-100">
      <div class="flex gap-4 py-4">
        <dt class="w-32 shrink-0 text-sm font-medium text-slate-500">入学日</dt>
        <dd class="text-sm text-slate-900">
          <%= @student.admission_date&.strftime("%Y年%-m月%-d日") || "未設定" %>
        </dd>
      </div>
      <% if @student.memo.present? %>
        <div class="py-4">
          <dt class="text-sm font-medium text-slate-500 mb-2">メモ</dt>
          <dd class="text-sm text-slate-900 whitespace-pre-wrap"><%= @student.memo %></dd>
        </div>
      <% end %>
    </dl>
  </div>
</div>
