<% content_for :title, "生徒詳細" %>

<div class="md:w-2/3 w-full">
  <h1 class="font-bold text-section-heading text-plum-black mb-6">生徒詳細</h1>

  <%= render @student %>

  <div class="flex flex-wrap gap-2 mt-6">
    <% if current_user&.admin? %>
      <%= link_to "編集", edit_student_path(@student), class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
      <%= button_to "削除", @student, method: :delete, form_class: "inline", class: "rounded-button px-3.5 py-2.5 bg-error-red hover:bg-red-700 text-black font-normal text-button cursor-pointer", data: { turbo_confirm: "本当に削除しますか？" } %>
    <% end %>
    <%= link_to "一覧に戻る", students_path, class: "rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
  </div>
</div>
