<% content_for :title, "Students" %>

<div class="w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-700 text-white mb-5 font-medium rounded-button inline-block" id="notice"><%= notice %></p>
  <% end %>

  <div class="flex justify-between items-center">
    <h1 class="font-bold text-section-heading text-plum-black">生徒一覧</h1>
    <%= link_to "新規生徒", new_student_path, class: "rounded-button px-3.5 py-2.5 bg-pinterest-red hover:bg-red-700 text-black block font-normal text-button" %>
  </div>

  <div id="students" class="min-w-full divide-y divide-gray-200 space-y-5 mt-8">
    <% if @students.any? %>
      <% @students.each do |student| %>
        <div class="flex flex-col sm:flex-row justify-between items-center pb-5 sm:pb-0">
          <%= render student %>
          <div class="w-full sm:w-auto flex flex-col sm:flex-row space-x-2 space-y-2">
            <%= link_to "詳細", student, class: "w-full sm:w-auto text-center rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
            <%= link_to "編集", edit_student_path(student), class: "w-full sm:w-auto text-center rounded-button px-3.5 py-2.5 bg-sand-gray hover:bg-warm-light text-black inline-block font-normal text-button" %>
            <%= button_to "削除", student, method: :delete, class: "w-full sm:w-auto rounded-button px-3.5 py-2.5 text-black bg-error-red hover:bg-red-700 font-normal text-button cursor-pointer", data: { turbo_confirm: "本当に削除しますか？" } %>
          </div>
        </div>
      <% end %>
    <% else %>
      <p class="text-center my-10 text-olive-gray text-body">生徒はまだいません。</p>
    <% end %>
  </div>
</div>
