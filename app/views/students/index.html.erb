<% content_for :title, "生徒管理" %>

<%= render "shared/page_header",
    title: "生徒管理",
    subtitle: "在籍生徒の情報を管理します",
    action: (current_user&.admin? ? link_to("＋ 新規生徒登録", new_student_path,
      class: "inline-flex items-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors") : nil) %>

<% if @students.any? %>
  <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
    <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-slate-200 bg-slate-50">
          <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">名前</th>
          <th class="text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">在籍状況</th>
          <th class="hidden sm:table-cell text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">カテゴリ</th>
          <th class="hidden sm:table-cell text-left px-6 py-3 text-xs font-semibold text-slate-500 uppercase tracking-wide">入学日</th>
          <th class="px-6 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-slate-100">
        <% @students.each do |student| %>
          <tr class="hover:bg-slate-50 transition-colors">
            <td class="px-6 py-4 font-medium text-slate-900"><%= student.name %></td>
            <td class="px-6 py-4">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= enrollment_status_badge_class(student.enrollment_status) %>">
                <%= enrollment_status_label(student.enrollment_status) %>
              </span>
            </td>
            <td class="hidden sm:table-cell px-6 py-4">
              <% if student.tag %>
                <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-indigo-100 text-indigo-700">
                  <%= student.tag.name %>
                </span>
              <% else %>
                <span class="text-xs text-slate-400">—</span>
              <% end %>
            </td>
            <td class="hidden sm:table-cell px-6 py-4 text-slate-500">
              <%= student.admission_date&.strftime("%Y年%-m月%-d日") || "—" %>
            </td>
            <td class="px-6 py-4">
              <div class="flex flex-wrap items-center justify-end gap-1">
                <%= link_to "詳細", student,
                    class: "text-xs font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-md px-3 py-1.5 transition-colors" %>
                <% if current_user&.admin? %>
                  <%= link_to "編集", edit_student_path(student),
                      class: "text-xs font-medium text-slate-600 hover:text-indigo-600 border border-slate-200 hover:border-indigo-300 rounded-md px-3 py-1.5 transition-colors" %>
                  <%= button_to "削除", student, method: :delete,
                      class: "text-xs font-medium text-red-500 hover:text-red-700 border border-red-200 hover:border-red-400 rounded-md px-3 py-1.5 transition-colors cursor-pointer bg-transparent",
                      data: { turbo_confirm: "#{student.name} を削除しますか？" } %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
    </div>
  </div>
<% else %>
  <%= render "shared/empty_state",
      icon: "👤",
      message: "まだ生徒が登録されていません",
      action: (current_user&.admin? ? link_to("生徒を登録する", new_student_path,
        class: "inline-flex mt-6 items-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white transition-colors") : nil) %>
<% end %>
