<!DOCTYPE html>
<html lang="ja">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} | 日報アプリ" : "日報アプリ" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-slate-50 font-sans text-slate-900 antialiased">

    <nav class="bg-white border-b border-slate-200 sticky top-0 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

          <div class="flex items-center gap-8">
            <%= link_to root_path, class: "flex items-center gap-2" do %>
              <span class="text-indigo-600 text-xl">📋</span>
              <span class="font-bold text-lg text-slate-900">日報アプリ</span>
            <% end %>

            <% if logged_in? %>
              <div class="hidden sm:flex items-center gap-1">
                <%= link_to "日報一覧", reports_path,
                    class: "px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors" %>
                <%= link_to "生徒管理", students_path,
                    class: "px-3 py-2 rounded-md text-sm font-medium text-slate-600 hover:text-indigo-600 hover:bg-indigo-50 transition-colors" %>
              </div>
            <% end %>
          </div>

          <div class="flex items-center gap-3">
            <% if logged_in? %>
              <span class="hidden sm:block text-sm text-slate-500"><%= current_user.name %></span>
              <%= button_to "ログアウト", session_path, method: :delete,
                  class: "text-sm font-medium text-slate-500 hover:text-red-600 bg-transparent border-0 cursor-pointer transition-colors" %>
            <% else %>
              <%= link_to "ログイン", new_session_path,
                  class: "text-sm font-medium text-indigo-600 hover:text-indigo-700" %>
            <% end %>
          </div>

        </div>
      </div>
    </nav>

    <% flash.each do |type, msg| %>
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-4">
        <div class="rounded-lg px-4 py-3 flex items-center gap-2 <%= flash_class(type) %>">
          <span class="text-sm font-medium"><%= msg %></span>
        </div>
      </div>
    <% end %>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <%= yield %>
    </main>

  </body>
</html>
