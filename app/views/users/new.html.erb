<% content_for :title, "アカウント登録" %>

<div class="min-h-[70vh] flex items-center justify-center py-12">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <span class="text-5xl">📋</span>
      <h1 class="mt-4 text-2xl font-bold text-slate-900">アカウント登録</h1>
      <p class="mt-2 text-sm text-slate-500">新しいアカウントを作成します</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
      <div class="mb-6">
        <%= render "shared/form_errors", object: @user %>
      </div>

      <%= form_with(model: @user, local: true, class: "space-y-5") do |form| %>

        <div>
          <%= form.label :name, "名前", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.text_field :name,
              placeholder: "山田 太郎",
              autocomplete: "name",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <div>
          <%= form.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.email_field :email,
              placeholder: "example@email.com",
              autocomplete: "email",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <div>
          <%= form.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <p class="text-xs text-slate-400 mb-1.5">8文字以上</p>
          <%= form.password_field :password,
              autocomplete: "new-password",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <div>
          <%= form.label :password_confirmation, "パスワード確認", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.password_field :password_confirmation,
              autocomplete: "new-password",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <%= form.submit "登録する",
            class: "w-full flex justify-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors cursor-pointer mt-2" %>

      <% end %>
    </div>

    <p class="mt-6 text-center text-sm text-slate-500">
      すでにアカウントをお持ちの方は
      <%= link_to "ログインはこちら", new_session_path, class: "font-medium text-indigo-600 hover:text-indigo-700 hover:underline" %>
    </p>

  </div>
</div>
