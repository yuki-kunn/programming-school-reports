<% if page.current? %>
  <span class="inline-flex items-center justify-center min-w-[2.25rem] h-9 px-2 rounded-lg text-sm font-semibold bg-indigo-600 text-white">
    <%= page %>
  </span>
<% else %>
  <%= link_to page, url, class: "inline-flex items-center justify-center min-w-[2.25rem] h-9 px-2 rounded-lg text-sm font-medium bg-white text-slate-600 border border-slate-200 hover:border-indigo-300 hover:text-indigo-600 transition-colors", rel: page.next? ? "next" : (page.prev? ? "prev" : nil) %>
<% end %>
