<div class="flex min-h-full flex-col justify-center px-6 py-12 lg:px-8">
  <div class="sm:mx-auto sm:w-full sm:max-w-sm">
    <h2 class="mt-10 text-center text-section-heading font-semibold leading-9 tracking-tight text-plum-black">ログイン</h2>
  </div>

  <div class="mt-10 sm:mx-auto sm:w-full sm:max-w-sm">
    <%= form_with(url: session_path, scope: :session, local: true, class: "space-y-6") do |form| %>
      <div>
        <%= form.label :email, "メールアドレス", class: "block text-caption-bold leading-6 text-plum-black" %>
        <div class="mt-2">
          <%= form.email_field :email, class: "block w-full rounded-button border border-warm-silver py-2.5 px-3.5 text-plum-black shadow-sm focus:border-focus-blue focus:ring-focus-blue sm:text-body" %>
        </div>
      </div>

      <div>
        <div class="flex items-center justify-between">
          <%= form.label :password, "パスワード", class: "block text-caption-bold leading-6 text-plum-black" %>
        </div>
        <div class="mt-2">
          <%= form.password_field :password, class: "block w-full rounded-button border border-warm-silver py-2.5 px-3.5 text-plum-black shadow-sm focus:border-focus-blue focus:ring-focus-blue sm:text-body" %>
        </div>
      </div>

      <div>
        <%= form.submit "ログイン", class: "flex w-full justify-center rounded-button bg-pinterest-red py-1.5 px-3.5 text-body font-normal leading-6 text-black shadow-sm hover:bg-red-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-pinterest-red" %>
      </div>
    <% end %>
  </div>
</div>
