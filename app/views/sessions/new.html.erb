<% content_for :title, "ログイン" %>

<div class="min-h-[70vh] flex items-center justify-center py-12">
  <div class="w-full max-w-md">

    <div class="text-center mb-8">
      <span class="text-5xl">📋</span>
      <h1 class="mt-4 text-2xl font-bold text-slate-900">日報アプリ</h1>
      <p class="mt-2 text-sm text-slate-500">アカウントにログインしてください</p>
    </div>

    <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
      <%= form_with(url: session_path, scope: :session, local: true, class: "space-y-5") do |form| %>

        <div>
          <%= form.label :email, "メールアドレス", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.email_field :email,
              placeholder: "example@email.com",
              autocomplete: "email",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <div>
          <%= form.label :password, "パスワード", class: "block text-sm font-medium text-slate-700 mb-1.5" %>
          <%= form.password_field :password,
              autocomplete: "current-password",
              class: "block w-full rounded-lg border border-slate-300 px-3 py-2.5 text-sm text-slate-900 placeholder-slate-400 focus:border-indigo-500 focus:ring-1 focus:ring-indigo-500 outline-none transition" %>
        </div>

        <%= form.submit "ログイン",
            class: "w-full flex justify-center rounded-lg bg-indigo-600 hover:bg-indigo-700 px-4 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors cursor-pointer mt-2" %>

      <% end %>
    </div>

    <p class="mt-6 text-center text-sm text-slate-500">
      アカウントをお持ちでない方は
      <%= link_to "こちらから登録", new_user_path, class: "font-medium text-indigo-600 hover:text-indigo-700 hover:underline" %>
    </p>

  </div>
</div>
